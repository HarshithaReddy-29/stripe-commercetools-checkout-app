{
  "name": "payment-capture-job",
  "version": "1.0.0",
  "description": "Stripe Payment capture job",  
  "main": "index.js",
  "private": true,
"scripts": {
  "prebuild": "npm --prefix ../processor install && npm --prefix ../processor run build",
  "build": "rimraf ./build && tsc",
  "start": "node build/index.js",
    "lint": "eslint . --ext .ts",
    "prettier": "prettier --write '**/*.{js,ts}'",
    "test": "jest --config jest.config.cjs",
    "test:coverage": "npm run prebuild && jest --config jest.config.cjs --coverage",
    "test:watch": "jest --watch"
},
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@gmsb/processor": "file:../processor"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "rimraf": "^5.0.1"
  }
}